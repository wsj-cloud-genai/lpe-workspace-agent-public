GOOGLE_API_KEY=<YOUR_GEMINI_API_KEY>
GCP_PROJECT=<YOUR_GCP_PROJECT_ID>
LOG_LEVEL=DEBUG

# LPE Platform API Keys
LPE_ADMIN_KEY=<YOUR_LPE_ADMIN_KEY>
LPE_PUBLIC_KEY=<YOUR_LPE_PUBLIC_KEY>

# Firebase Configuration
VITE_FIREBASE_API_KEY=<YOUR_FIREBASE_API_KEY>
VITE_FIREBASE_AUTH_DOMAIN=<YOUR_DOMAIN>
VITE_FIREBASE_PROJECT_ID=<YOUR_GCP_PROJECT_ID>
VITE_FIREBASE_STORAGE_BUCKET=<YOUR_PROJECT_ID>.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<YOUR_SENDER_ID>
VITE_FIREBASE_APP_ID=<YOUR_APP_ID>

# Google Meet Recordings Folder ID (where Google Meet auto-saves transcripts)
GOOGLE_MEET_RECORDINGS_FOLDER_ID=<YOUR_MEET_RECORDINGS_FOLDER_ID>

# MCP Server Configuration
MCP_SERVICE_ACCOUNT=<YOUR_SERVICE_ACCOUNT_EMAIL>
